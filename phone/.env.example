# Copy to .env and load with:  flutter run --dart-define-from-file=.env
# Keys map to fromEnvironment() constants in lib/config.dart.

# Backend server URL.
#   production:        https://livetranslate.hellovia.app
#   emulator → Mac:    http://10.0.2.2:4000
#   device → LAN:      http://192.168.x.x:4000
SERVER_URL=https://livetranslate.hellovia.app

# Google sign-in gate. true = require login, false = skip it (dev).
REQUIRE_AUTH=true
