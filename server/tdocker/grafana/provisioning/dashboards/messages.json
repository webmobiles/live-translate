{
  "title": "Messages",
  "uid": "live-translate-messages",
  "tags": ["live-translate"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Messages (last 24h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "expr": "sum(count_over_time({service=\"live-translate-server\", event=\"message.text.received\"} [24h]))", "queryType": "instant", "datasource": { "type": "loki", "uid": "loki" } }]
    },
    {
      "id": 2,
      "title": "Voice Messages (last 24h)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "expr": "sum(count_over_time({service=\"live-translate-server\", event=\"message.audio.received\"} [24h]))", "queryType": "instant", "datasource": { "type": "loki", "uid": "loki" } }]
    },
    {
      "id": 3,
      "title": "Active Rooms",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "expr": "sum(count_over_time({service=\"live-translate-server\", event=\"room.created\"} [24h]))", "queryType": "instant", "datasource": { "type": "loki", "uid": "loki" } }]
    },
    {
      "id": 4,
      "title": "Translation Failures (last 24h)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "expr": "sum(count_over_time({service=\"live-translate-server\"} | json | event=\"translation.failed\" [24h]))", "queryType": "instant", "datasource": { "type": "loki", "uid": "loki" } }]
    },
    {
      "id": 5,
      "title": "Messages Per Minute",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum(count_over_time({service=\"live-translate-server\", event=\"message.text.received\"} [$__auto]))", "legendFormat": "Text messages", "datasource": { "type": "loki", "uid": "loki" } },
        { "expr": "sum(count_over_time({service=\"live-translate-server\", event=\"message.audio.received\"} [$__auto]))", "legendFormat": "Voice messages", "datasource": { "type": "loki", "uid": "loki" } }
      ]
    },
    {
      "id": 6,
      "title": "Messages by Language",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "options": { "pieType": "donut", "legendDisplayMode": "table", "legendPlacement": "right" },
      "targets": [{ "expr": "sum by (senderLang) (count_over_time({service=\"live-translate-server\"} | json | event=\"message.text.received\" [$__range]))", "legendFormat": "{{senderLang}}", "datasource": { "type": "loki", "uid": "loki" } }]
    },
    {
      "id": 7,
      "title": "Recent Messages Log",
      "type": "logs",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "wrapLogMessage": true, "prettifyLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending" },
      "targets": [{ "expr": "{service=\"live-translate-server\"} | json | event=~\"message\\\\.(text|audio)\\\\.received\"", "datasource": { "type": "loki", "uid": "loki" } }]
    }
  ]
}
