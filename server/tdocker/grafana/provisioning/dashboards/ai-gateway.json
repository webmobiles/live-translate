{
  "title": "AI Gateway — Translation Provider",
  "uid": "live-translate-ai-gateway",
  "tags": ["live-translate", "ai", "translation"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [

    { "id": 1, "type": "stat", "title": "Ollama Translations (24 h)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "sum(count_over_time({service=\"live-translate-server\"} | json | event=\"translation.ok\" | provider=\"ollama\" [24h]))",
        "queryType": "instant", "legendFormat": "Ollama"
      }]
    },

    { "id": 2, "type": "stat", "title": "OpenAI Translations (24 h)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" }, "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "sum(count_over_time({service=\"live-translate-server\"} | json | event=\"translation.ok\" | provider=\"openai\" [24h]))",
        "queryType": "instant", "legendFormat": "OpenAI"
      }]
    },

    { "id": 3, "type": "stat", "title": "Avg Ollama Latency (1 h)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "super-light-blue" }, "unit": "ms", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "avg(avg_over_time({service=\"live-translate-server\"} | json | event=\"translation.ok\" | provider=\"ollama\" | unwrap durationMs [1h]))",
        "queryType": "instant", "legendFormat": "ms"
      }]
    },

    { "id": 4, "type": "stat", "title": "Avg OpenAI Latency (1 h)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "yellow" }, "unit": "ms", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "avg(avg_over_time({service=\"live-translate-server\"} | json | event=\"translation.ok\" | provider=\"openai\" | unwrap durationMs [1h]))",
        "queryType": "instant", "legendFormat": "ms"
      }]
    },

    { "id": 5, "type": "stat", "title": "Translation Errors (24 h)",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "red", "value": 1 }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "sum(count_over_time({service=\"live-translate-server\"} | json | event=\"translation.failed\" [24h]))",
        "queryType": "instant", "legendFormat": "Errors"
      }]
    },

    { "id": 6, "type": "stat", "title": "Retries (24 h)",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "orange", "value": 1 }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "sum(count_over_time({service=\"live-translate-server\"} | json | event=\"translation.retry_failed\" [24h]))",
        "queryType": "instant", "legendFormat": "Retries"
      }]
    },

    { "id": 7, "type": "piechart", "title": "Provider Split (24 h)",
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byFrameRefID", "options": "Ollama" }, "properties": [{ "id": "displayName", "value": "Ollama" }] },
          { "matcher": { "id": "byFrameRefID", "options": "OpenAI" }, "properties": [{ "id": "displayName", "value": "OpenAI" }] }
        ]
      },
      "options": { "pieType": "donut", "legendDisplayMode": "table", "legendPlacement": "bottom" },
      "targets": [
        {
          "refId": "Ollama",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service=\"live-translate-server\"} | json | event=\"translation.ok\" | provider=\"ollama\" [24h]))",
          "queryType": "instant"
        },
        {
          "refId": "OpenAI",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service=\"live-translate-server\"} | json | event=\"translation.ok\" | provider=\"openai\" [24h]))",
          "queryType": "instant"
        }
      ]
    },

    { "id": 8, "type": "timeseries", "title": "Translations per Minute by Provider",
      "gridPos": { "x": 6, "y": 4, "w": 18, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "palette-classic" },
          "unit": "reqpm"
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "sum by (provider) (rate({service=\"live-translate-server\"} | json | event=\"translation.ok\" [$__rate_interval])) * 60",
        "legendFormat": "{{provider}}"
      }]
    },

    { "id": 9, "type": "timeseries", "title": "Avg Translation Latency by Provider (ms)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "decimals": 0
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "avg by (provider) (avg_over_time({service=\"live-translate-server\"} | json | event=\"translation.ok\" | unwrap durationMs [$__rate_interval]))",
        "legendFormat": "{{provider}}"
      }]
    },

    { "id": 10, "type": "timeseries", "title": "Errors & Retries per Minute by Provider",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" },
          "unit": "reqpm"
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (provider) (rate({service=\"live-translate-server\"} | json | event=\"translation.failed\" [$__rate_interval])) * 60",
          "legendFormat": "{{provider}} failures"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (provider) (rate({service=\"live-translate-server\"} | json | event=\"translation.retry_failed\" [$__rate_interval])) * 60",
          "legendFormat": "{{provider}} retries"
        }
      ]
    },

    { "id": 11, "type": "timeseries", "title": "Latency by Language Pair",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "decimals": 0
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "avg by (provider, senderLang, targetLang) (avg_over_time({service=\"live-translate-server\"} | json | event=\"translation.ok\" | unwrap durationMs [$__rate_interval]))",
        "legendFormat": "{{provider}} {{senderLang}}→{{targetLang}}"
      }]
    },

    { "id": 12, "type": "logs", "title": "Recent Translation Activity",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "wrapLogMessage": true, "prettifyLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending" },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "{service=\"live-translate-server\"} | json | event=~\"translation\\\\..*\""
      }]
    }

  ]
}
