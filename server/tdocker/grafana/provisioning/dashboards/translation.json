{
  "title": "Translation",
  "uid": "live-translate-translation",
  "tags": ["live-translate"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Translations (last 24h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "expr": "sum(increase(live_translate_messages_total[24h]))", "legendFormat": "Total", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 2,
      "title": "Words Translated (last 24h)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" }, "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "expr": "sum(increase(live_translate_words_total[24h]))", "legendFormat": "Words", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 3,
      "title": "Voice Minutes (last 24h)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "unit": "m",
          "decimals": 1
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "expr": "sum(increase(live_translate_audio_input_seconds_total[24h])) / 60", "legendFormat": "Minutes", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 9,
      "title": "Voice Duration Per Minute by Language",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum by (language) (rate(live_translate_audio_input_seconds_total[$__rate_interval])) * 60", "legendFormat": "{{language}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 10,
      "title": "Cumulative Voice Seconds by Language",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum by (language) (live_translate_audio_input_seconds_total)", "legendFormat": "{{language}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 4,
      "title": "Translation Failures (last 24h)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "expr": "sum(count_over_time({service=\"live-translate-server\"} | json | event=\"translation.failed\" [24h]))", "queryType": "instant", "datasource": { "type": "loki", "uid": "loki" } }]
    },
    {
      "id": 5,
      "title": "TTS Requests (last 24h)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" }, "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "expr": "sum(increase(live_translate_tts_requests_total[24h]))", "legendFormat": "TTS", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 6,
      "title": "Messages Per Minute by Type",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum by (type) (rate(live_translate_messages_total[$__rate_interval]))", "legendFormat": "{{type}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 7,
      "title": "Words by Language",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" } },
      "options": { "pieType": "donut", "legendDisplayMode": "table", "legendPlacement": "right" },
      "targets": [{ "expr": "sum by (language) (increase(live_translate_words_total[$__range]))", "legendFormat": "{{language}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 11,
      "title": "Messages by Provider",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byFrameRefID", "options": "Ollama" }, "properties": [{ "id": "displayName", "value": "Ollama" }] },
          { "matcher": { "id": "byFrameRefID", "options": "OpenAI" }, "properties": [{ "id": "displayName", "value": "OpenAI" }] }
        ]
      },
      "options": { "pieType": "donut", "legendDisplayMode": "table", "legendPlacement": "right" },
      "targets": [
        {
          "refId": "Ollama",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service=\"live-translate-server\"} | json | event=\"translation.ok\" | provider=\"ollama\" [$__range]))",
          "queryType": "instant"
        },
        {
          "refId": "OpenAI",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service=\"live-translate-server\"} | json | event=\"translation.ok\" | provider=\"openai\" [$__range]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 8,
      "title": "Translation Failure Log",
      "type": "logs",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "wrapLogMessage": true, "prettifyLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending" },
      "targets": [{ "expr": "{service=\"live-translate-server\"} | json | event=~\"translation\\\\..*failed\"", "datasource": { "type": "loki", "uid": "loki" } }]
    }
  ]
}
