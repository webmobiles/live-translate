{
  "title": "Phone Client Logs",
  "uid": "live-translate-phone-client",
  "tags": ["live-translate", "phone", "client"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Phone Logs (last 24h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"live-translate-server\"} | json | source=\"client\" | clientApp=\"phone\" [24h]))",
          "queryType": "instant",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ]
    },
    {
      "id": 2,
      "title": "Socket Connect Errors (last 24h)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"live-translate-server\", event=\"client.socket.connect_error\"} | json | clientApp=\"phone\" [24h]))",
          "queryType": "instant",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP Errors (last 24h)",
      "type": "stat",
      "gridPos": { "x": 9, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"live-translate-server\", event=\"client.http.response\"} | json | clientApp=\"phone\" | statusCode >= 400 [24h]))",
          "queryType": "instant",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ]
    },
    {
      "id": 4,
      "title": "Create Room Acks (last 24h)",
      "type": "stat",
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"live-translate-server\", event=\"client.socket.ack\"} | json | clientApp=\"phone\" | eventName=\"room:create\" [24h]))",
          "queryType": "instant",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ]
    },
    {
      "id": 5,
      "title": "Phone Client Events",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (event) (count_over_time({service=\"live-translate-server\"} | json | source=\"client\" | clientApp=\"phone\" [$__auto]))",
          "legendFormat": "{{event}}",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ]
    },
    {
      "id": 6,
      "title": "HTTP Status Codes",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "sum by (statusCode) (count_over_time({service=\"live-translate-server\", event=\"client.http.response\"} | json | clientApp=\"phone\" [$__range]))",
          "legendFormat": "{{statusCode}}",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ]
    },
    {
      "id": 7,
      "title": "Socket Events",
      "type": "barchart",
      "gridPos": { "x": 8, "y": 12, "w": 8, "h": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "sum by (event) (count_over_time({service=\"live-translate-server\"} | json | clientApp=\"phone\" | event=~\"client\\\\.socket\\\\..*\" [$__range]))",
          "legendFormat": "{{event}}",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ]
    },
    {
      "id": 8,
      "title": "Slow Phone Requests",
      "type": "logs",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "wrapLogMessage": true, "prettifyLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{service=\"live-translate-server\"} | json | clientApp=\"phone\" | durationMs >= 1000",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ]
    },
    {
      "id": 9,
      "title": "Recent Phone Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 19, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "wrapLogMessage": true, "prettifyLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "{service=\"live-translate-server\"} | json | source=\"client\" | clientApp=\"phone\"",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ]
    }
  ]
}
