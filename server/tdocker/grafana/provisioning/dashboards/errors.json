{
  "title": "Errors",
  "uid": "live-translate-errors",
  "tags": ["live-translate"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "P1 (last 24h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "expr": "sum(count_over_time({service=\"live-translate-server\"} | json | severity=\"P1\" [24h]))", "queryType": "instant", "datasource": { "type": "loki", "uid": "loki" } }]
    },
    {
      "id": 2,
      "title": "P2 (last 24h)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "expr": "sum(count_over_time({service=\"live-translate-server\"} | json | severity=\"P2\" [24h]))", "queryType": "instant", "datasource": { "type": "loki", "uid": "loki" } }]
    },
    {
      "id": 3,
      "title": "P3 (last 24h)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "expr": "sum(count_over_time({service=\"live-translate-server\"} | json | severity=\"P3\" [24h]))", "queryType": "instant", "datasource": { "type": "loki", "uid": "loki" } }]
    },
    {
      "id": 4,
      "title": "Error Rate Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum(count_over_time({service=\"live-translate-server\"} | json | severity=\"P1\" [$__auto]))", "legendFormat": "P1", "datasource": { "type": "loki", "uid": "loki" } },
        { "expr": "sum(count_over_time({service=\"live-translate-server\"} | json | severity=\"P2\" [$__auto]))", "legendFormat": "P2", "datasource": { "type": "loki", "uid": "loki" } },
        { "expr": "sum(count_over_time({service=\"live-translate-server\"} | json | severity=\"P3\" [$__auto]))", "legendFormat": "P3", "datasource": { "type": "loki", "uid": "loki" } }
      ]
    },
    {
      "id": 5,
      "title": "Errors by Event",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" } },
      "options": { "orientation": "horizontal", "xTickLabelRotation": 0 },
      "targets": [{ "expr": "sum by (event) (count_over_time({service=\"live-translate-server\"} | json | severity=~\"P1|P2\" [$__range]))", "legendFormat": "{{event}}", "datasource": { "type": "loki", "uid": "loki" } }]
    },
    {
      "id": 6,
      "title": "Recent P1 / P2 Log Lines",
      "type": "logs",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "wrapLogMessage": true, "prettifyLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending" },
      "targets": [{ "expr": "{service=\"live-translate-server\"} | json | severity=~\"P1|P2\"", "datasource": { "type": "loki", "uid": "loki" } }]
    }
  ]
}
