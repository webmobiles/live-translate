PORT=4000
OPENAI_API_KEY=sk-...
# OpenAI health check is warning-only by default, so fallback behavior can be tested.
STARTUP_OPENAI_REQUIRED=false
TRANSLATION_PROVIDER=openai
# Use "mock" for local development without OpenAI quota.
# TRANSLATION_PROVIDER=mock
# Set to true to force real OpenAI translation even when TRANSLATION_PROVIDER=mock.
FORCE_AI_TRANSLATION=false

# Speech-to-text provider: openai, mock, faster-whisper, or vosk.
STT_PROVIDER=openai
FASTER_WHISPER_COMMAND=faster-whisper
FASTER_WHISPER_MODEL=small
# Optional: override CLI args. Available placeholders: {file}, {language}, {model}
# FASTER_WHISPER_ARGS={file} --model {model} --language {language}
VOSK_COMMAND=vosk-transcribe
VOSK_MODEL_PATH=
# Optional: override CLI args. Available placeholders: {file}, {language}, {model}
# VOSK_ARGS={file} --model {model} --language {language}

# Text-to-speech provider: none, mock, openai, or local.
TTS_PROVIDER=none
TTS_OPENAI_MODEL=gpt-4o-mini-tts
TTS_OPENAI_VOICE=coral
TTS_RESPONSE_FORMAT=mp3
LOCAL_TTS_COMMAND=
# Local TTS command should print base64 audio to stdout.
# LOCAL_TTS_ARGS=--text {text} --language {language} --voice {voice}
LOCAL_TTS_MIME_TYPE=audio/wav

# Direct speech-to-speech / voice translation provider.
# Batch workflows support mock now; OpenAI realtime needs a streaming session path.
VOICE_TRANSLATION_PROVIDER=none

# Database provider: scylla, tikv, or surreal.
# The tikv provider connects through TiDB's MySQL-compatible SQL layer.
DB_PROVIDER=scylla

# Queue provider: nats or redpanda.
QUEUE_PROVIDER=nats
NATS_SERVERS=nats://localhost:4222

# Redpanda (Kafka), optional if QUEUE_PROVIDER=redpanda.
REDPANDA_BROKERS=localhost:19092

# Realtime Socket.IO adapter: none, dragonfly, or valkey.
# Use none for a single Socket.IO server.
REALTIME_PROVIDER=none
DRAGONFLY_URL=redis://localhost:6379
VALKEY_URL=redis://localhost:6380

# ScyllaDB
SCYLLA_HOSTS=localhost
SCYLLA_KEYSPACE=live_translate

# TiKV through TiDB SQL layer
TIKV_SQL_HOST=localhost
TIKV_SQL_PORT=14000
TIKV_SQL_USER=root
TIKV_SQL_PASSWORD=
TIKV_SQL_DATABASE=live_translate

# SurrealDB
SURREALDB_URL=http://localhost:8000/rpc
SURREALDB_NAMESPACE=live_translate
SURREALDB_DATABASE=live_translate
SURREALDB_USERNAME=root
SURREALDB_PASSWORD=root

# Inngest
INNGEST_DEV=1
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=local

# Observability
LOG_LEVEL=info
# Pretty terminal logs in development. Production should usually keep JSON logs.
LOG_PRETTY=true
# Set to 0 to disable periodic memory logs.
MEMORY_LOG_INTERVAL_MS=30000
LOG_SINK=loki
LOG_GATEWAY_BATCH_SIZE=25
LOG_GATEWAY_FLUSH_INTERVAL_MS=2000

# Loki local dev
LOKI_URL=http://127.0.0.1:3100/loki/api/v1/push

# OpenObserve local Docker UI:
#   cd server/tdocker
#   docker compose --profile observability up -d openobserve
#   open http://localhost:5080
OPENOBSERVE_URL=http://127.0.0.1:5080
OPENOBSERVE_ORG=default
OPENOBSERVE_LOG_STREAM=live_translate_server
OPENOBSERVE_USER=root@example.com
OPENOBSERVE_PASSWORD="Complexpass#123"
# Set true when you want the local Node server to push Pino logs to OpenObserve.
OPENOBSERVE_LOGS_ENABLED=false

# OpenTelemetry
# Set true to export auto-instrumented traces and runtime metrics.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=live-translate-server
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OpenObserve self-hosted auth for OTLP usually uses Basic auth.
# Default local OpenObserve value for root@example.com:Complexpass#123:
# OTEL_EXPORTER_OTLP_HEADERS="Authorization=Basic cm9vdEBleGFtcGxlLmNvbTpDb21wbGV4cGFzcyMxMjM="
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_METRIC_EXPORT_INTERVAL_MS=15000
