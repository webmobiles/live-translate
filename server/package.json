{
  "name": "live-translate-server",
  "version": "1.0.0",
  "description": "Live Translation Gateway Server",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "nodemon --watch src --ext ts --exec \"node --import tsx --import ./src/observability/tracing.ts src/server.ts\"",
    "start": "node --require ./dist/observability/tracing.js dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "cassandra-driver": "^4.9.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "inngest": "^4.5.0",
    "kafkajs": "^2.2.4",
    "mysql2": "^3.22.5",
    "nats": "^2.29.3",
    "openai": "^4.67.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^11.2.0",
    "redis": "^6.0.0",
    "socket.io": "^4.8.1",
    "surrealdb": "^2.0.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.19.20",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.7",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
