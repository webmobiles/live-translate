# Managed by Ansible — live-translate ({{ app_domain }})
# Uniquely-named map so it can't clash with other sites on this server.
map $http_upgrade $lt_connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    listen [::]:80;
    server_name {{ app_domain }};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name {{ app_domain }};

    ssl_certificate     /etc/letsencrypt/live/{{ app_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ app_domain }}/privkey.pem;

    # Voice-message audio + profile-image uploads
    client_max_body_size 25m;

    root {{ web_root }};
    index index.html;

    # Backend: API, auth, health, uploads, and the Socket.IO websocket
    location ~ ^/(api|auth|health|uploads|client|socket\.io)(/|$) {
        proxy_pass http://127.0.0.1:{{ api_port }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade            $http_upgrade;
        proxy_set_header Connection         $lt_connection_upgrade;
        proxy_set_header Host               $host;
        proxy_set_header X-Real-IP          $remote_addr;
        proxy_set_header X-Forwarded-For    $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto  $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # Never expose the internal API or Prometheus metrics publicly
    location ~ ^/(internal|metrics)(/|$) { return 404; }

    # Hashed Vite assets — cache hard
    location /assets/ {
        try_files $uri =404;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # SPA fallback for the web client
    location / {
        try_files $uri /index.html;
    }
}
